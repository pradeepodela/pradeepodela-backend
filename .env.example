## Backend environment template
## Use either SERVICE_ACCOUNT_KEY_PATH (local dev) or SERVICE_ACCOUNT_KEY_JSON (inline JSON)
## In production (Firebase Functions), credentials are provided automatically — omit these.

SERVICE_ACCOUNT_KEY_PATH=/Users/your-user/Downloads/your-firebase-adminsdk.json

## Comma-separated frontend URLs for CORS
FRONTEND_ORIGINS=http://localhost:8080,https://voiceflow-6c4c7.web.app

## AI providers
GROQ_API_KEY=
OPENROUTER_API_KEY=

## Embeddings — Nomic Atlas (free tier, separate from OpenRouter)
## Get key at: https://atlas.nomic.ai → Settings → API Keys  (format: nk-...)
NOMIC_API_KEY=nk-N20rsJsT4GUixlhfIjEEue7YCwGs4HDnZwbSlOfUwss
## Set to 'hash' to skip Nomic and use local bag-of-words (no key needed, worse quality)
EMBEDDING_PROVIDER=nomic
